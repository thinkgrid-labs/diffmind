{
  "name": "diffmind",
  "version": "0.4.9",
  "private": true,
  "description": "Local-first AI code review agent — powered by on-device Wasm inference",
  "author": "Thinkgrid Labs <dennis@thinkgrid.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thinkgrid-labs/diffmind.git"
  },
  "bugs": {
    "url": "https://github.com/thinkgrid-labs/diffmind/issues"
  },
  "homepage": "https://github.com/thinkgrid-labs/diffmind#readme",
  "keywords": [
    "ai",
    "code-review",
    "wasm",
    "security",
    "rust",
    "local-first",
    "typescript"
  ],
  "scripts": {
    "build:wasm": "pnpm --filter @diffmind/core-wasm build",
    "build:native": "pnpm --filter @diffmind/core-native build",
    "build:types": "pnpm --filter @diffmind/shared-types build",
    "build:cli": "pnpm --filter @diffmind/cli build",
    "build": "pnpm build:wasm && pnpm build:types && pnpm build:cli",
    "dev:cli": "pnpm --filter @diffmind/cli dev",
    "lint:types": "pnpm --filter @diffmind/shared-types build",
    "lint:cli": "pnpm --filter @diffmind/cli build",
    "lint": "pnpm build:wasm && pnpm lint:types && pnpm lint:cli",
    "test:wasm": "pnpm --filter @diffmind/core-wasm test",
    "sync-version": "node scripts/sync-versions.js",
    "test:js": "jest",
    "test": "pnpm test:js && pnpm test:wasm"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9"
  }
}